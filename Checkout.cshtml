@page
@model MediaLibrarySystem.Pages.CheckoutModel
@{
    ViewData["Title"] = "Checkout";
}
<!-- Written by Brian McCarthy -->
<h1>Order Summary</h1>
<div class="row">
    <div class="col-md-8">
        <ul class="list-group">
            @foreach(var item in Model.CartItems) {
                <li class="list-group-item">@item.Title - $@item.Price</li>
            }
        </ul>
    </div>
    <div class="col-md-4">
        <div class="card p-3">
            <h3>Total: $@Model.Total</h3>
            <button class="btn btn-block btn-primary">Process Payment</button>
        </div>
    </div>
</div>
